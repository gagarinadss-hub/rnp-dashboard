# Папка с данными (launches.db). Вне git-клона — переживает обновления кода.
DATA_DIR=/opt/rnp-data
# Интервал авто-импорта, секунды (600 = 10 минут)
IMPORT_TTL=600
# Токен вебхука/служебных эндпоинтов
WEBHOOK_TOKEN=rnp-bot-2026
# Google service account: проще положить файл credentials.json рядом с кодом
# (/opt/rnp-dashboard/credentials.json). Либо раскомментировать и вставить JSON:
# GOOGLE_CREDENTIALS={"type":"service_account", ... }
